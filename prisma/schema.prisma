datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SystemConfig {
  key   String @id
  value String
}

model Channel {
  id           String   @id // ID del canal de YouTube (p. ej. UC...)
  title        String
  thumbnail    String?
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Video {
  id             String    @id @default(uuid())
  filename       String
  filePath       String    // Ruta del archivo local en el servidor
  title          String?
  description    String?
  tags           String?   // Guardado como string separado por comas
  scheduledAt    DateTime?
  status         String    @default("DRAFT") // DRAFT, ANALYZING, READY, SCHEDULED, UPLOADING, COMPLETED, FAILED
  youtubeId      String?
  errorMessage   String?
  uploadProgress  Int       @default(0)
  thumbnailBase64 String?
  createdAt       DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model VideoTask {
  id            String    @id @default(uuid())
  youtubeId     String    @unique
  title         String
  description   String
  thumbnailText String?
  uploadDate    DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  status        String    @default("PENDING") // PENDING, COMPLETED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
