datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SystemConfig {
  key   String @id
  value String
}

model Channel {
  dbId         String   @id @default(uuid())
  id           String   // ID del canal de YouTube (p. ej. UC...)
  title        String
  thumbnail    String?
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  userEmail    String   @unique // El correo del trabajador al que pertenece esta conexión
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Video {
  id              String    @id @default(uuid())
  filename        String
  filePath        String    // Ruta del archivo local en el servidor
  title           String?
  description     String?
  tags            String?   // Guardado como string separado por comas
  scheduledAt     DateTime?
  status          String    @default("DRAFT") // DRAFT, ANALYZING, READY, SCHEDULED, UPLOADING, COMPLETED, FAILED
  youtubeId       String?
  errorMessage    String?
  uploadProgress  Int       @default(0)
  thumbnailBase64 String?
  rawFrameBase64  String?   // Frame extraído localmente por el navegador al subir
  playlistId      String?   // ID de la playlist a la que se añadirá el video
  userEmail       String?   // El correo del trabajador
  channelId       String?   // El ID del canal de YouTube
  privacyStatus   String?   // 'public', 'private', 'unlisted', etc.
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model VideoTask {
  id            String    @id @default(uuid())
  youtubeId     String    @unique
  title         String
  description   String
  thumbnailText String?
  uploadDate    DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  status        String    @default("PENDING") // PENDING, COMPLETED
  playlistId    String?   // ID de la playlist sugerida o seleccionada
  userEmail     String?   // El correo del trabajador
  channelId     String?   // El ID del canal de YouTube
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Playlist {
  id          String   @id // ID de la lista en YouTube (p. ej. PL...)
  title       String
  description String?
  thumbnail   String?
  channelId   String   // ID del canal al que pertenece
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProgramLogo {
  id         String   @id @default(uuid())
  name       String   @unique
  base64     String
  playlistId String?  // ID de la playlist de YouTube vinculada (ej. PLxxx)
  createdAt  DateTime @default(now())
}


