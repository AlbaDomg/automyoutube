# URL de la Base de Datos SQLite (Local)
DATABASE_URL="file:./dev.db"

# Clave de API de Gemini (Obtenla en Google AI Studio)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Credenciales de Google OAuth 2.0 (Obtenidas en Google Cloud Console para la API de YouTube)
YOUTUBE_CLIENT_ID="YOUR_YOUTUBE_CLIENT_ID"
YOUTUBE_CLIENT_SECRET="YOUR_YOUTUBE_CLIENT_SECRET"

# URL base de la aplicación para el redireccionamiento de OAuth
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Configuración de Supabase Storage (Almacenamiento Temporal Pendiente)
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
