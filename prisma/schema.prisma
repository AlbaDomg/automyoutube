datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SystemConfig {
  key   String @id
  value String
}

model Channel {
  id           String   @id // ID del canal de YouTube (p. ej. UC...)
  title        String
  thumbnail    String?
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Video {
  id              String    @id @default(uuid())
  filename        String
  filePath        String    // Ruta del archivo local en el servidor
  title           String?
  description     String?
  tags            String?   // Guardado como string separado por comas
  scheduledAt     DateTime?
  status          String    @default("DRAFT") // DRAFT, ANALYZING, READY, SCHEDULED, UPLOADING, COMPLETED, FAILED
  youtubeId       String?
  errorMessage    String?
  uploadProgress  Int       @default(0)
  thumbnailBase64 String?
  playlistId      String?   // ID de la playlist a la que se añadirá el video
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model VideoTask {
  id            String    @id @default(uuid())
  youtubeId     String    @unique
  title         String
  description   String
  thumbnailText String?
  uploadDate    DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  status        String    @default("PENDING") // PENDING, COMPLETED
  playlistId    String?   // ID de la playlist sugerida o seleccionada
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Playlist {
  id          String   @id // ID de la lista en YouTube (p. ej. PL...)
  title       String
  description String?
  thumbnail   String?
  channelId   String   // ID del canal al que pertenece
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
